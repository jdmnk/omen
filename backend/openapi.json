    "/markets/search-slug": {
      "get": {
        "summary": "Get Market By Slug Endpoint",
        "description": "Get a market by its slug from Polymarket Gamma API.\n\nOfficial docs: https://docs.polymarket.com/api-reference/markets/get-market-by-slug",
        "operationId": "get_market_by_slug_endpoint_markets_search_slug_get",
