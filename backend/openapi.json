    "/onchain/updates": {
      "get": {
        "summary": "Get Updates Endpoint",
        "description": "Get all updates for a questionID and owner from the UMA CTF Adapter contract on-chain.\n\nCalls getUpdates(bytes32 questionID, address owner) on contract 0x6A9D222616C90FcA5754cd1333cFD9b7fb6a4F74.",
        "operationId": "get_updates_endpoint_onchain_updates_get",
        "parameters": [
          {
            "name": "question_id",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Question ID as hex string (bytes32)",
              "title": "Question Id"
            },
            "description": "Question ID as hex string (bytes32)"
          },
          {
            "name": "owner",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "description": "Owner address",
              "title": "Owner"
            },
            "description": "Owner address"
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AncillaryDataUpdate"
